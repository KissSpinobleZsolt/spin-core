# Copy this file to .env for local development (without Docker)
# Requires a local PostgreSQL instance on port 5432
DATABASE_URL=postgresql://cloudinsight:cloudinsight@localhost:5432/cloudinsight
JWT_SECRET_KEY=change-me-in-production
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
MODULE_REGISTRY_URLS=http://localhost:3001,http://localhost:3002
